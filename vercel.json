{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/refresh-active-products",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/cleanup-cache",
      "schedule": "0 3 * * *"
    }
  ]
}
