{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/import-products",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/sync-recalls",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/cron/sync-caers",
      "schedule": "10 5 * * 1"
    },
    {
      "path": "/api/cron/sync-warning-letters",
      "schedule": "20 5 * * 1"
    },
    {
      "path": "/api/cron/rescore-products",
      "schedule": "30 5 * * 1"
    }
  ]
}
