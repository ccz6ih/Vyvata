NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — falls back to deterministic report synthesis if unset
OPENAI_API_KEY=

# Optional — emails silently skipped if unset
RESEND_API_KEY=your-resend-api-key

# Required for /admin console. Generate with: openssl rand -hex 32
VYVATA_ADMIN_SECRET=
