# ══════════════════════════════════════════════════════════════
# Vyvata Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control
# See docs/ENV-SETUP.md for detailed setup instructions
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# SUPABASE (Required)
# ──────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Your Supabase project URL (e.g., https://abcdefghijk.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key (safe to expose in client-side code)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (NEVER expose to client, server-side only)
# Used for admin operations, bypassing RLS
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ──────────────────────────────────────────────────────────────
# ANTHROPIC CLAUDE (Optional - falls back to deterministic synthesis)
# ──────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
# Used for Claude-powered personalized protocol reports
# Without this, app uses deterministic fallback (less personalized but functional)

ANTHROPIC_API_KEY=sk-ant-api03-...
# Default: claude-opus-4-7. Override to claude-sonnet-4-6 for lower cost.
ANTHROPIC_MODEL=claude-opus-4-7

# ──────────────────────────────────────────────────────────────
# RESEND (Optional - emails silent-fail without this)
# ──────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
# Used for practitioner approval emails and access code recovery
# Sender: hello@vyvata.com (verify domain in Resend dashboard)

RESEND_API_KEY=re_Qbvj72SU_MtWbXELaQazbmuXoD7z8Vdrk

# ──────────────────────────────────────────────────────────────
# ADMIN AUTH (Required for admin console)
# ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used for /admin login authentication

VYVATA_ADMIN_SECRET=your-64-character-hex-string-here

# ──────────────────────────────────────────────────────────────
# NEXT.JS CONFIG (Optional)
# ──────────────────────────────────────────────────────────────

# Base URL for metadata and email links (production: https://vyvata.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────
# STRIPE (Phase 3 - not yet wired)
# ──────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Used for practitioner billing

# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ──────────────────────────────────────────────────────────────
# SENTRY (Optional - error tracking)
# ──────────────────────────────────────────────────────────────
# Get from: https://sentry.io/settings/projects/
# Used for production error monitoring

# SENTRY_DSN=https://abc123@o123456.ingest.sentry.io/123456
# NEXT_PUBLIC_SENTRY_DSN=https://abc123@o123456.ingest.sentry.io/123456

# ──────────────────────────────────────────────────────────────
# WEARABLE INTEGRATIONS (Phase 4 - not yet wired)
# ──────────────────────────────────────────────────────────────
# Oura, Whoop integrations for outcomes tracking

# OURA_CLIENT_ID=...
# OURA_CLIENT_SECRET=...
# WHOOP_CLIENT_ID=...
# WHOOP_CLIENT_SECRET=...
