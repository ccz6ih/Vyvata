# ══════════════════════════════════════════════════════════════
# Vyvata — Vercel Production Environment
# ══════════════════════════════════════════════════════════════
# Paste each KEY=VALUE into Vercel → Project → Settings → Environment Variables.
# Apply to: Production (and Preview if you want PR previews to work end-to-end).
# Never commit the filled-in version — .env.production is gitignored.
# ══════════════════════════════════════════════════════════════

# ─── SUPABASE ─────────────────────────────────────────────────
# From: https://supabase.com/dashboard/project/prsnobjebbxxchthbxfu/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://prsnobjebbxxchthbxfu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── APP URL ──────────────────────────────────────────────────
# Production domain (no trailing slash). Used in metadata and email links.
NEXT_PUBLIC_APP_URL=https://vyvata.com

# ─── ADMIN AUTH ───────────────────────────────────────────────
# 64-char hex string; generate with: openssl rand -hex 32
# Gates /admin console. Rotate if ever exposed.
VYVATA_ADMIN_SECRET=

# ─── ANTHROPIC CLAUDE (recommended for production) ────────────
# From: https://console.anthropic.com/settings/keys
# Without this, protocol reports fall back to deterministic synthesis.
ANTHROPIC_API_KEY=
# Default: claude-opus-4-7. Override to claude-sonnet-4-6 for lower cost.
ANTHROPIC_MODEL=claude-opus-4-7

# ─── RESEND ───────────────────────────────────────────────────
# From: https://resend.com/api-keys
# Sender domain must be verified (SPF/DKIM/DMARC green) for hello@vyvata.com.
RESEND_API_KEY=

# ─── SENTRY (optional, for error monitoring) ──────────────────
# From: https://sentry.io/settings/projects/
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# ─── STRIPE (Phase 3 — not yet wired) ─────────────────────────
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# ─── WEARABLES (Phase 4 — not yet wired) ──────────────────────
# OURA_CLIENT_ID=
# OURA_CLIENT_SECRET=
# WHOOP_CLIENT_ID=
# WHOOP_CLIENT_SECRET=
